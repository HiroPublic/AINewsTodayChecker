APP_NAME="AI News Verifier"
APP_ENV=local
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./app.db

# LLM provider switch
# Default: gemini
# Set to perplexity to use Perplexity API instead
VERIFIER_PROVIDER=gemini

SLACK_WEBHOOK_URL=

# Perplexity settings
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Gemini settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=

NOTIFY_SCORE_THRESHOLD=60

STATE_FILE_PATH=.state/last_run.json
PODCAST_RSS_URL=https://podcasts.loudandfound.com/ainewstoday/podcast.xml
PODCAST_APPLE_PODCAST_ID=1728333812
